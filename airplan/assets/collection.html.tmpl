<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light dark">
  {{if not .Indexable}}<meta name="robots" content="noindex,nofollow">{{end}}
  <title>{{.Title}}</title>
  <style>
    :root {
      color-scheme: light dark;
      --bg: light-dark(#ffffff, #0d1117);
      --fg: light-dark(#1f2328, #e6edf3);
      --heading: light-dark(#1f2328, #f0f6fc);
      --muted: light-dark(#59636e, #9198a1);
      --link: light-dark(#0969da, #4493f8);
      --border: light-dark(#d1d9e0, #3d444d);
      --surface: light-dark(#f6f8fa, #151b23);
      --control-hover: light-dark(#eff1f3, #21262d);
      --page-width: 54rem;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: var(--bg);
      color: var(--fg);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica,
        Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji";
      font-size: 16px;
      line-height: 1.7;
      -webkit-text-size-adjust: 100%;
    }
    .page-shell {
      width: min(100%, var(--page-width));
      min-height: 100vh;
      margin: 0 auto;
      padding: 0 1.5rem 4rem;
    }
    .toolbar {
      display: flex;
      flex-wrap: wrap;
      justify-content: flex-end;
      align-items: center;
      gap: .5rem;
      min-height: 3.5rem;
      padding-top: .75rem;
      font-size: .85rem;
    }
    .toolbar a,
    .toolbar button,
    .actions a,
    .actions button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.1rem;
      border: 0;
      border-radius: 8px;
      padding: .4rem .65rem;
      background: transparent;
      color: var(--muted);
      font: inherit;
      text-decoration: none;
      white-space: nowrap;
      cursor: pointer;
    }
    .toolbar a:hover,
    .toolbar button:hover,
    .actions a:hover,
    .actions button:hover {
      background: var(--control-hover);
      color: var(--fg);
    }
    :where(a, button):focus-visible {
      outline: 2px solid var(--link);
      outline-offset: 2px;
    }
    header {
      padding: 1.5rem 0 1.75rem;
      border-bottom: 1px solid var(--border);
    }
    h1 {
      margin: .35em 0 .35em;
      color: var(--heading);
      font-size: 2em;
      font-weight: 700;
      letter-spacing: -.025em;
      line-height: 1.25;
      overflow-wrap: anywhere;
    }
    .summary {
      margin: 0;
      color: var(--muted);
      font-size: .9rem;
    }
    .files {
      margin: 0;
      padding: 0;
      list-style: none;
    }
    .file {
      padding: 1.5rem 0 1.75rem;
      border-bottom: 1px solid var(--border);
    }
    .file-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
    }
    .details { min-width: 0; }
    .details h2 {
      margin: 0;
      color: var(--heading);
      font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas,
        "Liberation Mono", monospace;
      font-size: .95rem;
      font-weight: 600;
      line-height: 1.5;
      overflow-wrap: anywhere;
    }
    .meta {
      margin-top: .2rem;
      color: var(--muted);
      font-size: .8rem;
      overflow-wrap: anywhere;
    }
    .actions {
      display: flex;
      flex: none;
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: .15rem;
      margin: -.35rem 0 0;
      font-size: .82rem;
    }
    .actions a:first-child { color: var(--link); }
    .preview {
      display: flex;
      align-items: center;
      justify-content: center;
      margin-top: 1rem;
      overflow: hidden;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--surface);
    }
    .preview img,
    .preview video {
      display: block;
      width: 100%;
      max-height: 70vh;
      object-fit: contain;
    }
    .preview audio {
      width: min(100% - 2rem, 40rem);
      margin: 1.5rem 1rem;
    }
    @media (max-width: 36rem) {
      .page-shell { padding-inline: 1rem; }
      .toolbar { min-height: 3rem; }
      header { padding-top: 1rem; }
      h1 { font-size: 1.75em; }
      .file-header { display: block; }
      .actions {
        justify-content: flex-start;
        margin: .65rem 0 -.35rem -.65rem;
      }
    }
  </style>
</head>
<body>
<div class="page-shell">
  <nav class="toolbar" aria-label="Collection controls">
    <button type="button" data-copy-overview>Copy page link</button>
    {{with .RepositoryURL}}<a href="{{.}}">Repository</a>{{end}}
  </nav>
  <header>
    <h1>{{.Title}}</h1>
    <p class="summary">{{len .Files}} {{if eq (len .Files) 1}}file{{else}}files{{end}} · {{formatBytes .TotalBytes}}</p>
  </header>
  <ol class="files" aria-label="Uploaded files">
  {{range .Files}}<li class="file">
    <div class="file-header">
      <div class="details">
        <h2>{{.Name}}</h2>
        <div class="meta">{{.ContentType}} · {{formatBytes .Bytes}}</div>
      </div>
      <div class="actions">
        <a href="{{.Path}}">Open</a>
        <a href="{{.Path}}" download>Download</a>
        <button type="button" data-copy="{{.Path}}">Copy link</button>
      </div>
    </div>
    {{if ne .MediaKind "file"}}<div class="preview">
      {{if eq .MediaKind "image"}}<img src="{{.Path}}" alt="{{.Name}}" loading="lazy">{{end}}
      {{if eq .MediaKind "video"}}<video src="{{.Path}}" controls preload="metadata"></video>{{end}}
      {{if eq .MediaKind "audio"}}<audio src="{{.Path}}" controls preload="metadata"></audio>{{end}}
    </div>{{end}}
  </li>{{end}}
  </ol>
</div>
<script>document.addEventListener('click',async e=>{const b=e.target.closest('[data-copy],[data-copy-overview]');if(!b)return;const u=b.hasAttribute('data-copy-overview')?location.href:new URL(b.dataset.copy,document.baseURI).href;try{await navigator.clipboard.writeText(u);const old=b.textContent;b.textContent='Copied';setTimeout(()=>b.textContent=old,1200)}catch{prompt('Copy link',u)}})</script>
</body>
</html>
