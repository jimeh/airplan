<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="color-scheme" content="light dark">
{{- if not .Indexable}}
<meta name="robots" content="noindex, nofollow">
{{- end}}
<title>{{.Title}}</title>
<script>
/* airplan:theme-init-js */
</script>
<style>
/* airplan:shared-css */
/* airplan:collection-css */
</style>
</head>
<body>
<div class="page-shell">
<nav class="toolbar" aria-label="Collection controls">
  <div class="collection-actions toolbar-actions">
    <button type="button" data-copy-overview>Copy page link</button>
    {{- with .RepositoryURL}}
    <a href="{{.}}">Repository</a>
    {{- end}}
  </div>
<!-- airplan:theme-toggle -->
</nav>
<header>
  <h1>{{.Title}}</h1>
  <p class="summary">{{len .Files}} {{if eq (len .Files) 1}}file{{else}}files{{end}} · {{formatBytes .TotalBytes}}</p>
</header>
<ol class="files" aria-label="Uploaded files">
{{- range .Files}}
  <li class="file">
    <div class="file-header">
      <div class="details">
        <h2>{{.Name}}</h2>
        <div class="meta">{{.ContentType}} · {{formatBytes .Bytes}}</div>
      </div>
      <div class="actions">
        <a href="{{.Path}}">Open</a>
        <a href="{{.Path}}" download>Download</a>
        <button type="button" data-copy="{{.Path}}">Copy link</button>
      </div>
    </div>
    {{- if ne .MediaKind "file"}}
    <div class="preview preview--{{.MediaKind}}">
      {{- if eq .MediaKind "image"}}
      <a class="preview-link" href="{{.Path}}">
        <img src="{{.Path}}" alt="{{.Name}}" loading="lazy">
      </a>
      {{- end}}
      {{- if eq .MediaKind "video"}}
      <video src="{{.Path}}" controls preload="metadata"></video>
      {{- end}}
      {{- if eq .MediaKind "audio"}}
      <audio src="{{.Path}}" controls preload="metadata"></audio>
      {{- end}}
    </div>
    {{- end}}
  </li>
{{- end}}
</ol>
</div>
<script>
/* airplan:theme-js */
/* airplan:collection-js */
</script>
</body>
</html>
