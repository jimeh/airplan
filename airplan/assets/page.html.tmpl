<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
{{- if not .Indexable}}
<meta name="robots" content="noindex, nofollow">
{{- end}}
<title>{{.Title}}</title>
<style>
/* airplan:page-css */
{{.SyntaxCSS}}
</style>
</head>
<body>
<div class="page-shell">
{{- if or .SourcePath (and (eq .Format "md") .HighlightedSourceHTML)}}
<nav class="toolbar" aria-label="Document controls">
{{- if and (eq .Format "md") .HighlightedSourceHTML}}
  <div class="viewtoggle js-only" hidden>
    <button type="button" class="active" data-view="rendered"
      aria-pressed="true" aria-label="Rendered view"
      title="Rendered view"><svg class="icon" aria-hidden="true"
      viewBox="0 0 16 16" fill="currentColor"><path d="M8 2c1.981 0 3.671.992 4.933 2.078 1.27 1.091 2.187 2.345 2.637 3.023a1.62 1.62 0 0 1 0 1.798c-.45.678-1.367 1.932-2.637 3.023C11.67 13.008 9.981 14 8 14c-1.981 0-3.671-.992-4.933-2.078C1.797 10.83.88 9.576.43 8.898a1.62 1.62 0 0 1 0-1.798c.45-.677 1.367-1.931 2.637-3.022C4.33 2.992 6.019 2 8 2ZM1.679 7.932a.12.12 0 0 0 0 .136c.411.622 1.241 1.75 2.366 2.717C5.176 11.758 6.527 12.5 8 12.5c1.473 0 2.825-.742 3.955-1.715 1.124-.967 1.954-2.096 2.366-2.717a.12.12 0 0 0 0-.136c-.412-.621-1.242-1.75-2.366-2.717C10.824 4.242 9.473 3.5 8 3.5c-1.473 0-2.825.742-3.955 1.715-1.124.967-1.954 2.096-2.366 2.717ZM8 10a2 2 0 1 1-.001-3.999A2 2 0 0 1 8 10Z"/></svg><span>Rendered</span></button>
    <button type="button" data-view="source"
      aria-pressed="false" aria-label="Source view"
      title="Source view"><svg class="icon" aria-hidden="true"
      viewBox="0 0 16 16" fill="currentColor"><path d="m11.28 3.22 4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.749.749 0 0 1-1.275-.326.749.749 0 0 1 .215-.734L13.94 8l-3.72-3.72a.749.749 0 0 1 .326-1.275.749.749 0 0 1 .734.215Zm-6.56 0a.751.751 0 0 1 1.042.018.751.751 0 0 1 .018 1.042L2.06 8l3.72 3.72a.749.749 0 0 1-.326 1.275.749.749 0 0 1-.734-.215L.47 8.53a.75.75 0 0 1 0-1.06Z"/></svg><span>Source</span></button>
  </div>
  <button type="button" class="copy-source js-only" hidden
    aria-label="Copy markdown" title="Copy markdown"><svg
    class="icon icon-copy" aria-hidden="true" viewBox="0 0 16 16"
    fill="currentColor"><path d="M0 6.75C0 5.784.784 5 1.75 5h1.5a.75.75 0 0 1 0 1.5h-1.5a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-1.5a.75.75 0 0 1 1.5 0v1.5A1.75 1.75 0 0 1 9.25 16h-7.5A1.75 1.75 0 0 1 0 14.25Z"/><path d="M5 1.75C5 .784 5.784 0 6.75 0h7.5C15.216 0 16 .784 16 1.75v7.5A1.75 1.75 0 0 1 14.25 11h-7.5A1.75 1.75 0 0 1 5 9.25Zm1.75-.25a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-7.5a.25.25 0 0 0-.25-.25Z"/></svg><svg
    class="icon icon-check" aria-hidden="true" viewBox="0 0 16 16"
    fill="currentColor"><path d="M13.78 4.22a.75.75 0 0 1 0 1.06l-7.25 7.25a.75.75 0 0 1-1.06 0L2.22 9.28a.751.751 0 0 1 .018-1.042.751.751 0 0 1 1.042-.018L6 10.94l6.72-6.72a.75.75 0 0 1 1.06 0Z"/></svg><svg
    class="icon icon-x" aria-hidden="true" viewBox="0 0 16 16"
    fill="currentColor"><path d="M3.72 3.72a.75.75 0 0 1 1.06 0L8 6.94l3.22-3.22a.749.749 0 0 1 1.275.326.749.749 0 0 1-.215.734L9.06 8l3.22 3.22a.749.749 0 0 1-.326 1.275.749.749 0 0 1-.734-.215L8 9.06l-3.22 3.22a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042L6.94 8 3.72 4.78a.75.75 0 0 1 0-1.06Z"/></svg><span class="action-label">Copy</span></button>
{{- end}}
{{- if .SourcePath}}
  <a class="download" href="{{.SourcePath}}" download
    aria-label="Download {{if eq .Format "md"}}markdown{{else}}source{{end}}"
    title="Download {{if eq .Format "md"}}markdown{{else}}source{{end}}"><svg
    class="icon" aria-hidden="true" viewBox="0 0 16 16"
    fill="currentColor"><path d="M2.75 14A1.75 1.75 0 0 1 1 12.25v-2.5a.75.75 0 0 1 1.5 0v2.5c0 .138.112.25.25.25h10.5a.25.25 0 0 0 .25-.25v-2.5a.75.75 0 0 1 1.5 0v2.5A1.75 1.75 0 0 1 13.25 14Z"/><path d="M7.25 7.689V2a.75.75 0 0 1 1.5 0v5.689l1.97-1.969a.749.749 0 1 1 1.06 1.06l-3.25 3.25a.749.749 0 0 1-1.06 0L4.22 6.78a.749.749 0 1 1 1.06-1.06l1.97 1.969Z"/></svg><span>Download</span></a>
  <a class="raw" href="{{.SourcePath}}"
    aria-label="Open raw {{if eq .Format "md"}}markdown{{else}}source{{end}}"
    title="Open raw {{if eq .Format "md"}}markdown{{else}}source{{end}}"><svg
    class="icon" aria-hidden="true" viewBox="0 0 16 16"
    fill="currentColor"><path d="m11.28 3.22 4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.749.749 0 0 1-1.275-.326.749.749 0 0 1 .215-.734L13.94 8l-3.72-3.72a.749.749 0 0 1 .326-1.275.749.749 0 0 1 .734.215Zm-6.56 0a.751.751 0 0 1 1.042.018.751.751 0 0 1 .018 1.042L2.06 8l3.72 3.72a.749.749 0 0 1-.326 1.275.749.749 0 0 1-.734-.215L.47 8.53a.75.75 0 0 1 0-1.06Z"/></svg><span>Raw</span></a>
{{- end}}
</nav>
{{- end}}
{{- if .TOC}}
<nav class="toc" id="toc" aria-label="Table of contents">
  <p class="toc-title">Contents</p>
  <ol class="toc-list">
  {{- range .TOC}}
    <li class="toc-level-{{.Level}}"><a href="#{{.ID}}">{{.Text}}</a></li>
  {{- end}}
  </ol>
</nav>
{{- end}}
<main class="content" id="rendered">
{{- if and (eq .Format "txt") .SourceName}}
<div class="filehead"><code>{{.SourceName}}</code></div>
{{- end}}
{{.RenderedHTML}}
</main>
{{- if and (eq .Format "md") .HighlightedSourceHTML}}
<main class="content source-view" id="source" hidden>
<p class="source-heading"><svg class="icon" aria-hidden="true"
  viewBox="0 0 16 16" fill="currentColor"><path d="m11.28 3.22 4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.749.749 0 0 1-1.275-.326.749.749 0 0 1 .215-.734L13.94 8l-3.72-3.72a.749.749 0 0 1 .326-1.275.749.749 0 0 1 .734.215Zm-6.56 0a.751.751 0 0 1 1.042.018.751.751 0 0 1 .018 1.042L2.06 8l3.72 3.72a.749.749 0 0 1-.326 1.275.749.749 0 0 1-.734-.215L.47 8.53a.75.75 0 0 1 0-1.06Z"/></svg><span>Markdown source</span></p>
{{.HighlightedSourceHTML}}
</main>
{{- end}}
</div>
<script>
/* airplan:page-js */
</script>
{{- if and .HasMermaid (not .NoExternalAssets)}}
<script type="module" referrerpolicy="no-referrer">
const diagrams = Array.from(document.querySelectorAll('pre.mermaid'));
const sources = diagrams.map((diagram) => diagram.textContent);
try {
  const {default: mermaid} = await import({{.MermaidURL}});
  const dark = matchMedia('(prefers-color-scheme: dark)').matches;
  mermaid.initialize({
    startOnLoad: false,
    securityLevel: 'strict',
    theme: dark ? 'dark' : 'default'
  });
  await mermaid.run({nodes: diagrams});
} catch (error) {
  diagrams.forEach((diagram, index) => {
    diagram.textContent = sources[index];
    diagram.classList.add('mermaid-failed');
  });
  console.warn('airplan: Mermaid rendering failed', error);
}
</script>
{{- end}}
</body>
</html>
