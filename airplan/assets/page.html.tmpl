<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
{{- if .Noindex}}
<meta name="robots" content="noindex, nofollow">
{{- end}}
<title>{{.Title}}</title>
<style>
{{.CSS}}
{{.SyntaxCSS}}
</style>
</head>
<body>
{{- if or .SourcePath .SourceHTML}}
<nav class="toolbar">
{{- if .SourceHTML}}
  <div class="viewtoggle js-only" hidden>
    <button type="button" class="active" data-view="rendered"
      aria-pressed="true">Rendered</button>
    <button type="button" data-view="source"
      aria-pressed="false">Source</button>
  </div>
  <button type="button" class="copy-source js-only" hidden>
    Copy markdown</button>
{{- end}}
{{- if .SourcePath}}
  <a class="download" href="{{.SourcePath}}" download>{{.SourceLabel}}</a>
{{- end}}
</nav>
{{- end}}
<main class="content" id="rendered">
{{- if .FileName}}
<div class="filehead"><code>{{.FileName}}</code></div>
{{- end}}
{{.Body}}
</main>
{{- if .SourceHTML}}
<main class="content source-view" id="source" hidden>
{{.SourceHTML}}
</main>
{{- end}}
<script>
{{.JS}}
</script>
</body>
</html>
